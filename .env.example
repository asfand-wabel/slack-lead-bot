# Slack App credentials — get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token   # needed for Socket Mode
SLACK_SIGNING_SECRET=your-signing-secret
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
APP_URL=https://your-public-url.example.com   # public URL of this server (no trailing slash)

# Channel IDs to monitor (comma-separated, e.g. C012AB3CD,C987ZY6WX)
# Leave blank to listen on all channels the bot is in
WATCH_CHANNELS=

PORT=3000
